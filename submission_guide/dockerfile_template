# Paper2ARM Hackathon Dockerfile 模板
# 
# 本模板用于 DeployMaster 自动构建系统
# 基于 Bohrium 平台要求设计
#
# 使用说明:
# 1. 根据实际依赖修改 Python 包列表
# 2. 如需添加系统依赖，在 apt-get install 中添加
# 3. 确保不使用 COPY/ADD 指令（Bohrium 限制）
# 4. 镜像大小需控制在 40GB 以内

# =============================================================================
# 基础镜像
# =============================================================================
FROM registry.dp.tech/dptech/ubuntu:20.04-py3.10

# 设置环境变量
ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1

# =============================================================================
# 配置国内镜像源（Bohrium 平台要求）
# =============================================================================
RUN sed -i 's/archive.ubuntu.com/mirrors.aliyun.com/g' /etc/apt/sources.list && \
    sed -i 's/security.ubuntu.com/mirrors.aliyun.com/g' /etc/apt/sources.list

# 配置 pip 国内镜像源
RUN pip config set global.index-url https://pypi.tuna.tsinghua.edu.cn/simple && \
    pip config set install.trusted-host pypi.tuna.tsinghua.edu.cn

# =============================================================================
# 安装系统依赖 + SSH 组件（Bohrium 平台必需）
# =============================================================================
RUN apt-get update && apt-get install -y --no-install-recommends \
    # SSH 三件套（必需）
    openssh-server \
    supervisor \
    net-tools \
    # 基础工具
    git \
    wget \
    curl \
    ca-certificates \
    # 构建工具（如需编译 Python 包）
    build-essential \
    pkg-config \
    # 常见系统依赖（根据实际需要增删）
    libgl1-mesa-glx \
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    libxrender-dev \
    libgomp1 \
    # 清理缓存
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# =============================================================================
# SSH 服务配置（Bohrium 平台必需）
# =============================================================================
# 创建 SSH 运行目录
RUN mkdir -p /var/run/sshd

# 配置 SSH
RUN echo 'root:root' | chpasswd && \
    sed -i 's/#PermitRootLogin prohibit-password/PermitRootLogin yes/' /etc/ssh/sshd_config && \
    sed -i 's/UsePAM yes/UsePAM no/' /etc/ssh/sshd_config

# 配置 SSH 保活
RUN echo "ClientAliveInterval 60" >> /etc/ssh/sshd_config && \
    echo "ClientAliveCountMax 3" >> /etc/ssh/sshd_config

# =============================================================================
# 安装 Python 依赖
# =============================================================================
# 注意：根据实际项目需求修改以下包列表

RUN pip install --no-cache-dir -i https://pypi.tuna.tsinghua.edu.cn/simple \
    # 深度学习框架（按需选择）
    torch==2.0.1 \
    torchvision==0.15.2 \
    # tensorflow-cpu==2.13.0 \
    # 科学计算
    numpy==1.24.3 \
    scipy==1.11.1 \
    # 数据处理
    pandas==2.0.3 \
    # 可视化
    matplotlib==3.7.2 \
    seaborn==0.12.2 \
    plotly==5.15.0 \
    # 机器学习
    scikit-learn==1.3.0 \
    scikit-image==0.21.0 \
    # Jupyter（推荐安装，便于调试）
    jupyterlab==4.0.5 \
    notebook==7.0.2 \
    ipywidgets==8.1.0 \
    # 常用工具
    pyyaml==6.0.1 \
    tqdm==4.65.0 \
    pillow==10.0.0 \
    opencv-python==4.8.0.76 \
    # 其他常用包（按需增删）
    requests==2.31.0 \
    h5py==3.9.0

# =============================================================================
# 如需安装特定领域的包，请在此添加
# =============================================================================
# 示例：NLP 相关
# RUN pip install --no-cache-dir -i https://pypi.tuna.tsinghua.edu.cn/simple \
#     transformers==4.31.0 \
#     tokenizers==0.13.3 \
#     datasets==2.14.0

# 示例：图神经网络
# RUN pip install --no-cache-dir -i https://pypi.tuna.tsinghua.edu.cn/simple \
#     torch-geometric==2.3.1 \
#     networkx==3.1

# 示例：分子/材料科学
# RUN pip install --no-cache-dir -i https://pypi.tuna.tsinghua.edu.cn/simple \
#     ase==3.22.1 \
#     pymatgen==2023.7.14 \
#     rdkit==2023.3.2

# =============================================================================
# 如需从 GitHub 安装特定包
# =============================================================================
# RUN pip install --no-cache-dir git+https://github.com/username/repo.git@tag

# =============================================================================
# 设置工作目录
# =============================================================================
WORKDIR /root/Paper_Reproduction

# 创建工作子目录
RUN mkdir -p /root/Paper_Reproduction/{code,dataset,result,logs}

# =============================================================================
# 配置 Supervisor（进程管理）
# =============================================================================
RUN mkdir -p /etc/supervisor/conf.d && \
    echo '[supervisord]' > /etc/supervisor/conf.d/supervisord.conf && \
    echo 'nodaemon=true' >> /etc/supervisor/conf.d/supervisord.conf && \
    echo 'logfile=/var/log/supervisor/supervisord.log' >> /etc/supervisor/conf.d/supervisord.conf && \
    echo '' >> /etc/supervisor/conf.d/supervisord.conf && \
    echo '[program:sshd]' >> /etc/supervisor/conf.d/supervisord.conf && \
    echo 'command=/usr/sbin/sshd -D' >> /etc/supervisor/conf.d/supervisord.conf && \
    echo 'autostart=true' >> /etc/supervisor/conf.d/supervisord.conf && \
    echo 'autorestart=true' >> /etc/supervisor/conf.d/supervisord.conf

# =============================================================================
# 暴露端口和启动命令
# =============================================================================
EXPOSE 22

CMD ["/usr/bin/supervisord", "-c", "/etc/supervisor/conf.d/supervisord.conf"]

# =============================================================================
# 使用说明
# =============================================================================
# 1. 构建镜像:
#    docker build -f Dockerfile -t my-reproduction:latest .
#
# 2. 运行容器:
#    docker run -d -p 2222:22 my-reproduction:latest
#
# 3. SSH 登录:
#    ssh -p 2222 root@localhost
#    密码: root
#
# 4. 在 Bohrium 平台使用:
#    - 将 Dockerfile 内容粘贴到"镜像中心 → 自定义镜像 → 创建镜像"
#    - 或使用 DeployMaster API 自动构建
# =============================================================================
